# Ant Army Docker Environment Configuration
#
# Copy this file to .env and customize as needed:
#   cp .env.example .env
#
# The Docker Compose setup will automatically load variables from .env

# PostgreSQL Configuration
POSTGRES_USER=ant_army
POSTGRES_PASSWORD=ant_army_dev
POSTGRES_PORT=5432

# API Server Configuration
API_PORT=3030
RUST_LOG=ant_army_api=debug,tower_http=debug

# Data Directory
# All coordination data is stored in a centralized location
# Default: ~/.config/ant-army/data/
ANT_ARMY_DATA_DIR=${HOME}/.config/ant-army/data

# Future Service Configurations
# Uncomment and configure when adding additional services

# Qdrant (Vector Database)
# QDRANT_PORT=6333

# Redis (Caching)
# REDIS_PORT=6379
